# name: test/sql/qpdf_ops.test
# description: document-level qpdf operations — pdf_merge / pdf_split / pdf_rotate
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── fixtures: three single-page PDFs with distinctive markers, generated by
#    the extension's own COPY writer ──────────────────────────────────────────

statement ok
COPY (SELECT 'AlphaMergeMarker page one content' AS t) TO '__TEST_DIR__/qm1.pdf' (FORMAT pdf);

statement ok
COPY (SELECT 'BravoMergeMarker page two content' AS t) TO '__TEST_DIR__/qm2.pdf' (FORMAT pdf);

statement ok
COPY (SELECT 'CharlieMergeMarker page three content' AS t) TO '__TEST_DIR__/qm3.pdf' (FORMAT pdf);

query I
SELECT max(page_count) FROM read_pdf('__TEST_DIR__/qm1.pdf');
----
1

# ── NULL propagation ─────────────────────────────────────────────────────────

query I
SELECT pdf_merge(NULL, '__TEST_DIR__/nullmerge.pdf') IS NULL;
----
true

query I
SELECT pdf_merge(['__TEST_DIR__/qm1.pdf'], NULL) IS NULL;
----
true

query I
SELECT pdf_rotate(NULL, '__TEST_DIR__/nullrot.pdf', 90) IS NULL;
----
true

query I
SELECT pdf_rotate('__TEST_DIR__/qm1.pdf', NULL, 90) IS NULL;
----
true

# ── pdf_merge: list order becomes page order ─────────────────────────────────

query I
SELECT ends_with(
  pdf_merge(['__TEST_DIR__/qm1.pdf', '__TEST_DIR__/qm2.pdf', '__TEST_DIR__/qm3.pdf'],
            '__TEST_DIR__/qmerged.pdf'),
  'qmerged.pdf');
----
true

query I
SELECT max(page_count) FROM read_pdf('__TEST_DIR__/qmerged.pdf');
----
3

# page texts appear in list order
query II
SELECT page,
       CASE WHEN page = 1 THEN contains(text, 'AlphaMergeMarker')
            WHEN page = 2 THEN contains(text, 'BravoMergeMarker')
            ELSE contains(text, 'CharlieMergeMarker') END
FROM read_pdf('__TEST_DIR__/qmerged.pdf')
ORDER BY page;
----
1	true
2	true
3	true

# merging over an existing output overwrites it (COPY TO semantics)
query I
SELECT ends_with(
  pdf_merge(['__TEST_DIR__/qm3.pdf', '__TEST_DIR__/qm1.pdf'], '__TEST_DIR__/qmerged2.pdf'),
  'qmerged2.pdf');
----
true

query I
SELECT ends_with(
  pdf_merge(['__TEST_DIR__/qm1.pdf', '__TEST_DIR__/qm2.pdf', '__TEST_DIR__/qm3.pdf'],
            '__TEST_DIR__/qmerged2.pdf'),
  'qmerged2.pdf');
----
true

query I
SELECT max(page_count) FROM read_pdf('__TEST_DIR__/qmerged2.pdf');
----
3

# ── pdf_split: one single-page file per page, zero-padded to page-count width ─

query II
SELECT page, ends_with(file, 'qmerged_p' || page || '.pdf')
FROM pdf_split('__TEST_DIR__/qmerged.pdf', '__TEST_DIR__')
ORDER BY page;
----
1	true
2	true
3	true

# each split file exists, is single-page, and carries the original page's text
query I
SELECT max(page_count) = 1 AND bool_and(contains(text, 'AlphaMergeMarker'))
FROM read_pdf('__TEST_DIR__/qmerged_p1.pdf');
----
true

query I
SELECT max(page_count) = 1 AND bool_and(contains(text, 'BravoMergeMarker'))
FROM read_pdf('__TEST_DIR__/qmerged_p2.pdf');
----
true

query I
SELECT max(page_count) = 1 AND bool_and(contains(text, 'CharlieMergeMarker'))
FROM read_pdf('__TEST_DIR__/qmerged_p3.pdf');
----
true

# ── pdf_rotate: multiples of 90 succeed, page count and text survive ─────────

query I
SELECT ends_with(pdf_rotate('__TEST_DIR__/qmerged.pdf', '__TEST_DIR__/qrot90.pdf', 90), 'qrot90.pdf');
----
true

query I
SELECT max(page_count) FROM read_pdf('__TEST_DIR__/qrot90.pdf');
----
3

query I
SELECT bool_and(contains(text, 'MergeMarker')) FROM read_pdf('__TEST_DIR__/qrot90.pdf');
----
true

# explicit page range (qpdf-style numeric range string)
query I
SELECT ends_with(pdf_rotate('__TEST_DIR__/qmerged.pdf', '__TEST_DIR__/qrotsub.pdf', 180, '1-2'), 'qrotsub.pdf');
----
true

query I
SELECT max(page_count) FROM read_pdf('__TEST_DIR__/qrotsub.pdf');
----
3

# negative multiples of 90 are fine too
query I
SELECT ends_with(pdf_rotate('__TEST_DIR__/qmerged.pdf', '__TEST_DIR__/qrotneg.pdf', -90, 'all'), 'qrotneg.pdf');
----
true

# ── error cases ──────────────────────────────────────────────────────────────

# non-multiple-of-90 rotation
statement error
SELECT pdf_rotate('__TEST_DIR__/qmerged.pdf', '__TEST_DIR__/qrot45.pdf', 45);
----
degrees must be a multiple of 90

# missing input file (merge)
statement error
SELECT pdf_merge(['__TEST_DIR__/qpdf_no_such_input.pdf'], '__TEST_DIR__/qnever.pdf');
----
qpdf_no_such_input.pdf' does not exist

# missing input file (rotate)
statement error
SELECT pdf_rotate('__TEST_DIR__/qpdf_no_such_input.pdf', '__TEST_DIR__/qnever.pdf', 90);
----
qpdf_no_such_input.pdf' does not exist

# missing input file (split)
statement error
SELECT * FROM pdf_split('__TEST_DIR__/qpdf_no_such_input.pdf', '__TEST_DIR__');
----
qpdf_no_such_input.pdf' does not exist

# nonexistent output directory (merge)
statement error
SELECT pdf_merge(['__TEST_DIR__/qm1.pdf'], '__TEST_DIR__/qpdf_no_such_dir/out.pdf');
----
qpdf_no_such_dir' does not exist

# nonexistent output directory (split)
statement error
SELECT * FROM pdf_split('__TEST_DIR__/qmerged.pdf', '__TEST_DIR__/qpdf_no_such_dir');
----
qpdf_no_such_dir' does not exist

# empty input list
statement error
SELECT pdf_merge([], '__TEST_DIR__/qempty.pdf');
----
input list is empty

# NULL inside the input list
statement error
SELECT pdf_merge(['__TEST_DIR__/qm1.pdf', NULL], '__TEST_DIR__/qnull.pdf');
----
input list contains a NULL path

# rotate in place is refused (qpdf reads the source lazily during write)
statement error
SELECT pdf_rotate('__TEST_DIR__/qrot90.pdf', '__TEST_DIR__/qrot90.pdf', 90);
----
output path must differ from input path
