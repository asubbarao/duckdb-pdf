# name: test/sql/read_pdf_tables.test
# description: read_pdf_tables function tests
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── table.pdf: basic table extraction ────────────────────────────────────

# At least one table row returned
query I
SELECT COUNT(*) > 0 FROM read_pdf_tables('test/data/table.pdf');
----
true

# At least one table detected (table_index >= 0)
query I
SELECT COUNT(DISTINCT table_index) > 0 FROM read_pdf_tables('test/data/table.pdf');
----
true

# All rows come from page 1
query I
SELECT COUNT(*) = 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE page != 1;
----
true

# row_index increments from 0
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE row_index = 0;
----
true

# cells array is non-null and non-empty for all rows
query I
SELECT COUNT(*) = 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE cells IS NULL OR len(cells) = 0;
----
true

# Each row has exactly 3 cells (3-column table)
query I
SELECT COUNT(*) = 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE len(cells) != 3;
----
true

# Header row contains "Item" in the first cell
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE lower(cells[1]) = 'item';
----
true

# "Apples" appears as a cell value somewhere
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE list_contains(cells, 'Apples');
----
true

# "Bananas" appears as a cell value somewhere
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE list_contains(cells, 'Bananas');
----
true

# "Cherries" appears as a cell value somewhere
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE list_contains(cells, 'Cherries');
----
true

# Known price cell "9.99" or "Cherries" row: Qty = "100"
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/table.pdf')
WHERE list_contains(cells, '100');
----
true

# ── two_pages.pdf: no tables expected ────────────────────────────────────

# Plain text-only PDF should return 0 rows (no tables detected)
query I
SELECT COUNT(*) = 0 FROM read_pdf_tables('test/data/two_pages.pdf');
----
true

# ── financial_right_aligned.pdf: right-aligned numeric column ─────────────
# Generated by test/data/gen_table_fixtures.c (Account | Balance; amounts share
# a common right edge so naive xMin clustering would over-segment).

# Detects a table with exactly 2 columns
query I
SELECT COUNT(*) = 0
FROM read_pdf_tables('test/data/financial_right_aligned.pdf')
WHERE len(cells) != 2;
----
true

# At least 5 rows (header + 4 data rows)
query I
SELECT COUNT(*) >= 5 FROM read_pdf_tables('test/data/financial_right_aligned.pdf');
----
true

# Header labels present
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/financial_right_aligned.pdf')
WHERE list_contains(list_transform(cells, x -> lower(x)), 'account')
   OR list_contains(list_transform(cells, x -> lower(x)), 'balance');
----
true

# Right-aligned amounts survive as single cells (not shattered)
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/financial_right_aligned.pdf')
WHERE list_contains(cells, '1,234.56')
   OR list_contains(cells, '1234.56');
----
true

query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/financial_right_aligned.pdf')
WHERE list_contains(cells, '12,500.75')
   OR list_contains(cells, '12500.75');
----
true

query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/financial_right_aligned.pdf')
WHERE list_contains(cells, 'Cash');
----
true

# ── ruled_lattice.pdf: bordered / lattice table ───────────────────────────
# Generated by test/data/gen_table_fixtures.c (3-col x 4-row grid with stroked
# vertical and horizontal rules).

# Exactly 3 columns on every row
query I
SELECT COUNT(*) = 0
FROM read_pdf_tables('test/data/ruled_lattice.pdf')
WHERE len(cells) != 3;
----
true

# 4 rows (header + 3 data)
query I
SELECT COUNT(*) = 4 FROM read_pdf_tables('test/data/ruled_lattice.pdf');
----
true

# Header cells
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/ruled_lattice.pdf')
WHERE list_contains(cells, 'Region');
----
true

query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/ruled_lattice.pdf')
WHERE list_contains(cells, 'Units');
----
true

# Data cells land in the lattice bands
query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/ruled_lattice.pdf')
WHERE list_contains(cells, 'North');
----
true

query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/ruled_lattice.pdf')
WHERE list_contains(cells, '2500');
----
true

query I
SELECT COUNT(*) > 0
FROM read_pdf_tables('test/data/ruled_lattice.pdf')
WHERE list_contains(cells, 'West');
----
true

# ── error: missing file ───────────────────────────────────────────────────

statement error
SELECT * FROM read_pdf_tables('test/data/does_not_exist.pdf');
----
