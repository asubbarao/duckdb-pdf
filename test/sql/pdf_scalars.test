# name: test/sql/pdf_scalars.test
# description: Scalar function tests: pdf_to_text (library-backed, poppler-cpp)
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── pdf_to_text ───────────────────────────────────────────────────────────

# Returns non-empty text for hello.pdf
query I
SELECT length(pdf_to_text('test/data/hello.pdf')) > 0;
----
true

# Contains "Hello DuckDB" text
query I
SELECT pdf_to_text('test/data/hello.pdf') ILIKE '%Hello DuckDB%';
----
true

# table.pdf: physical layout should include column header words
query I
SELECT pdf_to_text('test/data/table.pdf', 'physical') ILIKE '%Item%';
----
true

query I
SELECT pdf_to_text('test/data/table.pdf', 'physical') ILIKE '%Apples%';
----
true

query I
SELECT pdf_to_text('test/data/table.pdf', 'physical') ILIKE '%Cherries%';
----
true

# reading layout also returns content
query I
SELECT pdf_to_text('test/data/hello.pdf', 'reading') ILIKE '%Hello DuckDB%';
----
true

# raw layout also returns content
query I
SELECT pdf_to_text('test/data/hello.pdf', 'raw') ILIKE '%Hello DuckDB%';
----
true

# two_pages.pdf: text contains content from both pages
query I
SELECT pdf_to_text('test/data/two_pages.pdf') ILIKE '%Alpha%';
----
true

query I
SELECT pdf_to_text('test/data/two_pages.pdf') ILIKE '%Beta%';
----
true

# ── pdf_to_xml ────────────────────────────────────────────────────────────

# pdftoxml-style document: per-page <page> elements wrapping <word> bboxes
query I
SELECT contains(pdf_to_xml('test/data/two_pages.pdf'), 'Alpha') AND contains(pdf_to_xml('test/data/two_pages.pdf'), '<page');
----
true

# Beta content from the second page is present, and words carry bbox attrs
query I
SELECT contains(pdf_to_xml('test/data/two_pages.pdf'), 'Beta') AND contains(pdf_to_xml('test/data/two_pages.pdf'), 'xMin=');
----
true

# Outer pdf2xml wrapper element is emitted
query I
SELECT contains(pdf_to_xml('test/data/two_pages.pdf'), '<pdf2xml>');
----
true

# ── pdf_to_html ───────────────────────────────────────────────────────────

# Valid HTML document containing page content
query I
SELECT contains(pdf_to_html('test/data/two_pages.pdf'), 'Beta') AND contains(lower(pdf_to_html('test/data/two_pages.pdf')), '<html');
----
true

# First-page content is present and the body/page structure is emitted
query I
SELECT contains(pdf_to_html('test/data/two_pages.pdf'), 'Alpha') AND contains(pdf_to_html('test/data/two_pages.pdf'), 'class="page"');
----
true

# ── pdf_to_svg (real raster render) ───────────────────────────────────────

# A single page renders to an SVG document
query I
SELECT starts_with(trim(pdf_to_svg('test/data/two_pages.pdf', 1)), '<') AND contains(pdf_to_svg('test/data/two_pages.pdf', 1), '<svg');
----
true

# The page is embedded as a base64 PNG data URI (PNG magic bytes -> iVBORw0KGgo)
query I
SELECT contains(pdf_to_svg('test/data/two_pages.pdf', 1), 'data:image/png;base64,iVBORw0KGgo');
----
true

# Both pages render independently to valid PNG-embedded SVGs
query I
SELECT contains(pdf_to_svg('test/data/two_pages.pdf', 2), 'data:image/png;base64,iVBORw0KGgo');
----
true

# Optional dpi overload renders too (lower dpi -> smaller raster -> shorter output)
query I
SELECT contains(pdf_to_svg('test/data/two_pages.pdf', 1, 72), 'data:image/png;base64,iVBORw0KGgo')
  AND length(pdf_to_svg('test/data/two_pages.pdf', 1, 72)) < length(pdf_to_svg('test/data/two_pages.pdf', 1, 150));
----
true

# ── errors: missing file / out-of-range page ──────────────────────────────

statement error
SELECT pdf_to_xml('test/data/does_not_exist.pdf');
----

statement error
SELECT pdf_to_html('test/data/does_not_exist.pdf');
----

statement error
SELECT pdf_to_svg('test/data/two_pages.pdf', 99);
----

statement error
SELECT pdf_to_svg('test/data/two_pages.pdf', 0);
----

# ── error: missing file ───────────────────────────────────────────────────

statement error
SELECT pdf_to_text('test/data/does_not_exist.pdf');
----
