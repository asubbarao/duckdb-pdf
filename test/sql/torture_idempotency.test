# name: test/sql/torture_idempotency.test
# description: repeated calls (50x) to scalars and table functions for accumulation crash smoke test
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── scalar pdf_to_text called 50 times ──────────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT pdf_to_text(concat('test/data/hello', CASE WHEN t.range >= 0 THEN '' ELSE 'x' END, '.pdf')) AS x) s WHERE length(s.x) > 0;
----
50

# ── table function scanned 50 times ─────────────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT count(*) AS n, t.range AS r FROM read_pdf('test/data/hello.pdf', auto_ocr := false)) s WHERE s.n >= 0;
----
50

# ── pdf_to_xml 50 times (markdown analog) ───────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT pdf_to_xml(concat('test/data/hello', CASE WHEN t.range >= 0 THEN '' ELSE 'x' END, '.pdf')) AS m) s WHERE length(s.m) > 0;
----
50

# ── mix lines + words repeated ──────────────────────────────────────────────

query I
SELECT count(*) FROM range(10) t,
  lateral (SELECT count(*) AS lw, t.range AS r1 FROM read_pdf_lines('test/data/two_pages.pdf', auto_ocr := false)) l,
  lateral (SELECT count(*) AS ww, t.range AS r2 FROM read_pdf_words('test/data/two_pages.pdf', auto_ocr := false)) w
WHERE l.lw > 0 AND w.ww > 0;
----
10
