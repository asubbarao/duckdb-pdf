# name: test/sql/torture_idempotency.test
# description: repeated calls (50x) to scalars and table functions for accumulation crash smoke test
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── scalar pdf_to_text called 50 times ──────────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT pdf_to_text('test/data/hello.pdf') AS x) s WHERE length(s.x) >= 0;
----
50

# ── table function scanned 50 times ─────────────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT count(*) AS n FROM read_pdf('test/data/hello.pdf', auto_ocr := false)) s WHERE s.n >= 0;
----
50

# ── pdf_to_xml 50 times (markdown analog) ───────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT pdf_to_xml('test/data/hello.pdf') AS m) s WHERE length(s.m) >= 0;
----
50

# ── mix lines + words repeated ──────────────────────────────────────────────

query I
SELECT count(*) FROM range(10) t,
  lateral (SELECT count(*) AS lw FROM read_pdf_lines('test/data/two_pages.pdf', auto_ocr := false)) l,
  lateral (SELECT count(*) AS ww FROM read_pdf_words('test/data/two_pages.pdf', auto_ocr := false)) w
WHERE l.lw > 0 AND w.ww > 0;
----
10
