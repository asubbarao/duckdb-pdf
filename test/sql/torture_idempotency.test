# name: test/sql/torture_idempotency.test
# description: repeated calls to scalars (50x correlated lateral) and table functions (UNION ALL of distinct paths) for accumulation crash smoke test
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── scalar pdf_to_text called 50 times ──────────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT pdf_to_text(concat('test/data/hello', CASE WHEN t.range >= 0 THEN '' ELSE 'x' END, '.pdf')) AS x) s WHERE length(s.x) > 0;
----
50

# ── table function bound+executed 12x via UNION ALL of distinct literal paths ─
# (lateral correlation is binder-rejected for table functions; UNION ALL
#  branches each bind+execute separately — result-level multiplicity proof)

query I
SELECT count(DISTINCT filename) = 4 AND count(*) = 15 FROM (
  SELECT filename FROM read_pdf('test/data/hello.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/two_pages.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/table.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/scanned.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/hello.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/two_pages.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/table.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/scanned.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/hello.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/two_pages.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/table.pdf', auto_ocr := false)
  UNION ALL SELECT filename FROM read_pdf('test/data/scanned.pdf', auto_ocr := false)
) u;
----
true

# ── pdf_to_xml 50 times (markdown analog) ───────────────────────────────────

query I
SELECT count(*) FROM range(50) t, lateral (SELECT pdf_to_xml(concat('test/data/hello', CASE WHEN t.range >= 0 THEN '' ELSE 'x' END, '.pdf')) AS m) s WHERE length(s.m) > 0;
----
50

# ── lines + words each bound+executed 9x via UNION ALL of distinct paths ─────
# (scanned.pdf excluded: yields 0 rows from lines/words, filename never appears)

query I
SELECT l.dl = 3 AND l.nl = 84 AND w.dw = 3 AND w.nw = 117 FROM
  (SELECT count(DISTINCT filename) AS dl, count(*) AS nl FROM (
    SELECT filename FROM read_pdf_lines('test/data/hello.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/two_pages.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/table.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/hello.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/two_pages.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/table.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/hello.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/two_pages.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_lines('test/data/table.pdf', auto_ocr := false)
  )) l,
  (SELECT count(DISTINCT filename) AS dw, count(*) AS nw FROM (
    SELECT filename FROM read_pdf_words('test/data/hello.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/two_pages.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/table.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/hello.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/two_pages.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/table.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/hello.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/two_pages.pdf', auto_ocr := false)
    UNION ALL SELECT filename FROM read_pdf_words('test/data/table.pdf', auto_ocr := false)
  )) w;
----
true
