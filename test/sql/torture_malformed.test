# name: test/sql/torture_malformed.test
# description: adversarial malformed / corrupt / bad-path inputs to all readers and scalars
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── runtime zero-byte fixture ───────────────────────────────────────────────

statement ok
COPY (SELECT 1 WHERE false) TO '__TEST_DIR__/zero.pdf' (FORMAT csv, HEADER false);

# ── zero-byte on all readers ────────────────────────────────────────────────

statement error
SELECT * FROM read_pdf('__TEST_DIR__/zero.pdf');
----
could not open

statement error
SELECT * FROM read_pdf_lines('__TEST_DIR__/zero.pdf');
----
could not open

statement error
SELECT * FROM read_pdf_words('__TEST_DIR__/zero.pdf');
----
could not open

statement error
SELECT * FROM read_pdf_tables('__TEST_DIR__/zero.pdf');
----
could not open

# ── zero-byte on scalars ────────────────────────────────────────────────────

statement error
SELECT pdf_to_text('__TEST_DIR__/zero.pdf');
----
could not open

statement error
SELECT pdf_to_html('__TEST_DIR__/zero.pdf');
----
could not open

statement error
SELECT pdf_to_xml('__TEST_DIR__/zero.pdf');
----
could not open

statement error
SELECT pdf_to_svg('__TEST_DIR__/zero.pdf', 1);
----
could not open

