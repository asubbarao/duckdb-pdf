# name: test/sql/pdf_to_png.test
# description: pdf_to_png raster render of page to PNG BLOB (reuses pdf_to_svg render path)
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── basic render + size + magic ─────────────────────────────────────────────

query I
SELECT octet_length(pdf_to_png('test/data/hello.pdf', 1)) > 100;
----
true

# PNG magic via slice (no LIKE/ILIKE anywhere in this file)
query I
SELECT pdf_to_png('test/data/hello.pdf', 1)[1:4] = '\x89PNG'::BLOB;
----
true

# ── dpi scaling changes size (higher dpi = more bytes) ──────────────────────

query I
SELECT octet_length(pdf_to_png('test/data/hello.pdf', 1, 300)) > octet_length(pdf_to_png('test/data/hello.pdf', 1, 50));
----
true

# ── dpi validation (1..2400) ────────────────────────────────────────────────

statement error
SELECT pdf_to_png('test/data/hello.pdf', 1, 0);
----
dpi must be between

statement error
SELECT pdf_to_png('test/data/hello.pdf', 1, 2401);
----
dpi must be between

# ── page validation (1-based, in range) ─────────────────────────────────────

statement error
SELECT pdf_to_png('test/data/hello.pdf', 0);
----
out of range

statement error
SELECT pdf_to_png('test/data/hello.pdf', 99);
----
out of range

# ── BLOB overload ───────────────────────────────────────────────────────────

query I
SELECT octet_length(pdf_to_png((SELECT content FROM read_blob('test/data/hello.pdf')), 1)) > 100;
----
true

# ── garbage input (not a PDF) ───────────────────────────────────────────────

statement error
SELECT pdf_to_png('test/data/text_as_pdf.pdf', 1);
----
could not open

# ── NULL propagation ────────────────────────────────────────────────────────

query I
SELECT pdf_to_png(NULL, 1) IS NULL;
----
true

query I
SELECT pdf_to_png('test/data/hello.pdf', NULL) IS NULL;
----
true

# ── distinct inputs in one query (proves TempFileGuard/UUID avoids collisions) ─

# Verification re-runs the query unoptimized and compares byte-for-byte, but
# poppler's rasterizer is not bit-stable across repeated renders on Windows
# (font-cache/antialiasing state drifts between runs), so identical calls can
# yield PNGs that differ in a few pixels. The assertion below only checks the
# PNG magic, which is stable — exempt just this block from verification.
statement ok
PRAGMA disable_verification

query I
SELECT bool_and(p[1:4] = '\x89PNG'::BLOB)
FROM (
  SELECT pdf_to_png('test/data/hello.pdf', 1) AS p
  UNION ALL
  SELECT pdf_to_png('test/data/two_pages.pdf', 2) AS p
);
----
true

statement ok
PRAGMA enable_verification
