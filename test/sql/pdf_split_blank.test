# name: test/sql/pdf_split_blank.test
# description: mailroom batch splitting on blank-page separators — pdf_split_blank
# group: [sql]

require pdf

statement ok
PRAGMA enable_verification

# ── fixture: test/data/blank_split.pdf (generated by test/data/gen_blank_split.py)
#    7 pages: [DOC A p1, DOC A p2, blank, DOC B p1, blank, blank, DOC C p1]
#    -> 3 documents: pages 1-2, page 4, page 7 ─────────────────────────────────

query I
SELECT max(page_count) FROM read_pdf('test/data/blank_split.pdf');
----
7

query IIIII
SELECT document, first_page, last_page, page_count,
       ends_with(file, 'blank_split_doc' || document || '.pdf')
FROM pdf_split_blank('test/data/blank_split.pdf', '__TEST_DIR__')
ORDER BY document;
----
1	1	2	2	true
2	4	4	1	true
3	7	7	1	true

# each emitted file is readable and carries the right content pages' text, in
# order (poppler text extraction appends trailing whitespace/form-feeds, and \r on Windows — trim)
query I
SELECT list(text ORDER BY page) FROM read_pdf('__TEST_DIR__/blank_split_doc1.pdf');
----
[DOC A PAGE 1, DOC A PAGE 2]

query I
SELECT list(text ORDER BY page) FROM read_pdf('__TEST_DIR__/blank_split_doc2.pdf');
----
[DOC B PAGE 1]

query I
SELECT list(text ORDER BY page) FROM read_pdf('__TEST_DIR__/blank_split_doc3.pdf');
----
[DOC C PAGE 1]

# consecutive blanks (pages 5-6) never produced a 4th (empty) document
query I
SELECT count(*) FROM pdf_split_blank('test/data/blank_split.pdf', '__TEST_DIR__');
----
3

# ── no-blank file: exactly 1 document spanning the whole file ────────────────

query IIII
SELECT document, first_page, last_page, page_count
FROM pdf_split_blank('test/data/two_pages.pdf', '__TEST_DIR__');
----
1	1	2	2

# ── error cases ──────────────────────────────────────────────────────────────

# missing input file
statement error
SELECT * FROM pdf_split_blank('test/data/does_not_exist_blank_split.pdf', '__TEST_DIR__');
----
does_not_exist_blank_split.pdf' does not exist

# nonexistent output directory
statement error
SELECT * FROM pdf_split_blank('test/data/blank_split.pdf', '__TEST_DIR__/no_such_split_blank_dir');
----
no_such_split_blank_dir' does not exist

# blank_threshold out of range
statement error
SELECT * FROM pdf_split_blank('test/data/blank_split.pdf', '__TEST_DIR__', blank_threshold := 0.0);
----
blank_threshold must be in (0, 1]

statement error
SELECT * FROM pdf_split_blank('test/data/blank_split.pdf', '__TEST_DIR__', blank_threshold := 1.5);
----
blank_threshold must be in (0, 1]
